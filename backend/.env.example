DATABASE_URL=sqlite:///./geniuscode.db
ADMIN_API_KEY=admin-secret-key-change-me
DEFAULT_RATE_LIMIT_RPM=60
DEFAULT_RATE_LIMIT_TPM=100000

# ── 上游：aicodewith（唯一供货上游，OpenAI 兼容中转）──
# base_url 与 key 以 aicodewith 控制台/接入文档为准
AICODEWITH_API_KEY=
AICODEWITH_BASE_URL=https://api.aicodewith.com/v1
AICODEWITH_TIMEOUT_SECONDS=60

# 以下为可选直连上游（当前默认全部走 aicodewith，可留空）
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
