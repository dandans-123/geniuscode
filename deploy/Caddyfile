# 自动申请 / 续期 Let's Encrypt 证书（需 80/443 放行 + 域名 A 记录已指向本机）

# 后端 API 子域名
api.geniuscode.online {
	encode zstd gzip
	reverse_proxy app:8000
}

# 站点根域名 + www：同一个 app 既托管前端静态页(/)，也提供 API。
# 前端 JS 的 API 请求统一打到 api.geniuscode.online，故此处直接反代 app 即可。
geniuscode.online, www.geniuscode.online {
	encode zstd gzip
	reverse_proxy app:8000
}

# 控制台:Sub2API(开源中转控制台),跑在宿主机 8080(systemd,非容器)。
app.geniuscode.online {
	encode zstd gzip
	reverse_proxy host.docker.internal:8080
}
