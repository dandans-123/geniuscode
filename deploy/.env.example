# ── 复制为 .env 后按实际填写（.env 已被 .gitignore 忽略，勿提交真实密钥）──

# 部署域名：A 记录需已解析到本服务器公网 IP
DOMAIN=api.geniuscode.online

# 上游 aicodewith（必填）。base_url/key 以 aicodewith 控制台为准
AICODEWITH_API_KEY=
AICODEWITH_BASE_URL=https://api.aicodewith.com/v1

# 数据库：持久化到 ./data 卷（四个斜杠 = 容器内绝对路径）
DATABASE_URL=sqlite:////app/data/geniuscode.db

# 安全密钥：生产务必改成随机长串
#   生成示例：  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_请改成随机长串
ADMIN_API_KEY=CHANGE_ME_管理员密钥

# 缺上游 key 时是否回落 mock：生产建议 false（直接报错，不返回假数据）。
# 若上线初期还没拿到 aicodewith key、想先看页面跑通，可临时设 true。
MOCK_WHEN_NO_UPSTREAM_KEY=false

# 前端跨域来源（GitHub Pages + 正式域名）
CORS_ORIGINS=https://dandans-123.github.io,https://geniuscode.online,https://api.geniuscode.online
